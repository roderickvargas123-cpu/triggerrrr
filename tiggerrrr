-- ==========================================
-- CONTROLES DE TECLADO
-- ==========================================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
    end

    if not gameProcessed and input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = true
        frame.BorderColor3 = Color3.fromRGB(0, 255, 0)
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = false
        frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

-- ==========================================
-- SISTEMA DE COMBO
-- ==========================================
local function DispararComboRapido()
    if firingCombo then return end
    firingCombo = true

    local secuencia = {Enum.KeyCode.Five, Enum.KeyCode.Four, Enum.KeyCode.Three}

    for _, tecla in ipairs(secuencia) do
        VirtualInputManager:SendKeyEvent(true, tecla, false, game)
        VirtualInputManager:SendKeyEvent(false, tecla, false, game)
        
        task.wait(0.01) 
        
        if mouse1click then
            mouse1click()
        else
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
        
        task.wait(0.01)
    end

    task.wait(0.5)
    firingCombo = false
end

-- ==========================================
-- MOTOR PRINCIPAL Y FILTRO FANTASMA
-- ==========================================
-- IMPORTANTE: Objeto creado fuera del bucle para evitar fugas de memoria (Crasheos)
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Include
rayParams.IgnoreWater = true

RunService.RenderStepped:Connect(function()
    if holdingTriggerButton and getgenv().XenoTriggerBot and LocalPlayer.Character then
        
        -- 1. CREAMOS LA LISTA DE BLANCOS VÁLIDOS
        local blancosValidos = {}
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                
                local char = player.Character
                local isKnocked = false
                local bodyEffects = char:FindFirstChild("BodyEffects")
                
                -- Búsqueda ultra segura: buscamos la bandera para no crashear
                if bodyEffects then
                    local koFlag = bodyEffects:FindFirstChild("K.O") or bodyEffects:FindFirstChild("KO") or bodyEffects:FindFirstChild("Knocked") or bodyEffects:FindFirstChild("Dead")
                    
                    -- Verificamos que exista y que sea un valor verdadero
                    if koFlag and koFlag:IsA("BoolValue") and koFlag.Value == true then
                        isKnocked = true
                    end
                end
                
                -- Si NO está noqueado, lo metemos a la lista de colisiones físicas
                if not isKnocked then
                    table.insert(blancosValidos, char)
                end
            end
        end
        
        -- 2. ACTUALIZAMOS EL RAYO
        rayParams.FilterDescendantsInstances = blancosValidos
        
        local mousePos = UserInputService:GetMouseLocation()
        local unitRay = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
        
        -- 3. EL DISPARO
        local rayResult = workspace:Raycast(unitRay.Origin, unitRay.Direction * 1000, rayParams)
        
        if rayResult and rayResult.Instance then
            local model = rayResult.Instance:FindFirstAncestorOfClass("Model")
            
            if model and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
                local targetPlayer = Players:GetPlayerFromCharacter(model)
                
                if targetPlayer and targetPlayer ~= LocalPlayer then
                    -- El rayo ya filtró a los noqueados, disparamos directo
                    DispararComboRapido()
                end
            end
        end
    end
end)
