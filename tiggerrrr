if getgenv().XenoTriggerBot then return end
getgenv().XenoTriggerBot = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local holdingTriggerButton = false
local firingCombo = false

local FOVCircle = Drawing.new("Circle")
FOVCircle.Radius = 60 
FOVCircle.Color = Color3.fromRGB(255, 0, 0)
FOVCircle.Thickness = 1.5
FOVCircle.Filled = false
FOVCircle.Visible = true

local hiddenUI = (gethui and gethui()) or CoreGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "XenoGUI"
screenGui.Parent = hiddenUI

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 70)
frame.Position = UDim2.new(0.02, 0, 0.05, 0)
frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
frame.BorderSizePixel = 2
frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
frame.Parent = screenGui

local textLabel = Instance.new("TextLabel")
textLabel.Size = UDim2.new(1, 0, 0, 40)
textLabel.BackgroundTransparency = 1
textLabel.Text = "[ XENO ACTIVADO: Hold 'P' ]"
textLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
textLabel.Font = Enum.Font.Code
textLabel.TextSize = 13
textLabel.Parent = frame

local hideLabel = Instance.new("TextLabel")
hideLabel.Size = UDim2.new(1, 0, 0, 20)
hideLabel.Position = UDim2.new(0, 0, 0, 40)
hideLabel.BackgroundTransparency = 1
hideLabel.Text = "[INSERT] para Ocultar Menú"
hideLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
hideLabel.Font = Enum.Font.SourceSans
hideLabel.TextSize = 14
hideLabel.Parent = frame

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
        FOVCircle.Visible = screenGui.Enabled
    end

    if not gameProcessed and input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = true
        frame.BorderColor3 = Color3.fromRGB(0, 255, 0)
        FOVCircle.Color = Color3.fromRGB(0, 255, 0)
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = false
        frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
        FOVCircle.Color = Color3.fromRGB(255, 0, 0)
    end
end)

local function DispararComboRapido()
    if firingCombo then return end
    firingCombo = true

    local secuencia = {Enum.KeyCode.Five, Enum.KeyCode.Four, Enum.KeyCode.Three}

    for _, tecla in ipairs(secuencia) do
        VirtualInputManager:SendKeyEvent(true, tecla, false, game)
        VirtualInputManager:SendKeyEvent(false, tecla, false, game)
        
        task.wait() 
        
        if mouse1click then
            mouse1click()
        else
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
        
        task.wait()
    end

    task.wait(0.2)
    firingCombo = false
end

RunService.RenderStepped:Connect(function()
    local mouseLocation = UserInputService:GetMouseLocation()
    FOVCircle.Position = mouseLocation

    if holdingTriggerButton and getgenv().XenoTriggerBot and LocalPlayer.Character then
        local objetivoEncontrado = false

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                
                local hitbox = player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Head")
                
                if hitbox then
                    local vector, onScreen = Camera:WorldToViewportPoint(hitbox.Position)
                    
                    if onScreen then
                        local distance = (Vector2.new(vector.X, vector.Y) - mouseLocation).Magnitude
                        
                        if distance <= FOVCircle.Radius then
                            objetivoEncontrado = true
                            break
                        end
                    end
                end
            end
        end

        if objetivoEncontrado then
            DispararComboRapido()
        end
    end
end)
