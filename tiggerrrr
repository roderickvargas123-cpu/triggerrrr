-- ==========================================
-- CONTROLES (SOPORTA MOUSE4 Y MOUSE5)
-- ==========================================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
        FOVCircle.Visible = screenGui.Enabled
    end

    -- Detecta tanto el botón 4 como el 5 por si Razer Synapse los invierte
    if not gameProcessed and (input.UserInputType == Enum.UserInputType.MouseButton5 or input.UserInputType == Enum.UserInputType.MouseButton4) then
        holdingTriggerButton = true
        FOVCircle.Color = Color3.fromRGB(0, 255, 0) -- Se pone verde al presionar
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton5 or input.UserInputType == Enum.UserInputType.MouseButton4 then
        holdingTriggerButton = false
        FOVCircle.Color = Color3.fromRGB(255, 0, 0) -- Vuelve a rojo
    end
end)

-- ==========================================
-- MACRO EXACTA DE AHK (SIMULADOR DE TECLAS)
-- ==========================================
local function DispararCombo()
    if firingCombo then return end
    firingCombo = true

    -- Orden exacto de tu AHK: Teclas 5, 4, 3
    local teclasCombo = {Enum.KeyCode.Five, Enum.KeyCode.Four, Enum.KeyCode.Three}

    for _, tecla in ipairs(teclasCombo) do
        -- 1. Simular presionar el número en el teclado
        VirtualInputManager:SendKeyEvent(true, tecla, false, game)
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(false, tecla, false, game)
        
        -- Pausa para que el juego saque el arma de la funda
        task.wait(0.05) 
        
        -- 2. Simular Clic Izquierdo para disparar
        if mouse1click then
            mouse1click()
        else
            -- Plan B si mouse1click falla: VirtualInputManager clic
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            task.wait(0.02)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
        
        -- Pausa antes de sacar la siguiente arma
        task.wait(0.05)
    end

    task.wait(0.5) -- Cooldown para no crashear
    firingCombo = false
end

-- ==========================================
-- TRIGGER BOT AVANZADO (MATH & ESP)
-- ==========================================
RunService.RenderStepped:Connect(function()
    local mouseLocation = UserInputService:GetMouseLocation()
    FOVCircle.Position = mouseLocation

    if holdingTriggerButton and getgenv().XenoTriggerBot then
        local objetivoEncontrado = false

        -- Escanear a todos los jugadores del servidor
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                
                -- Buscar el torso o la cabeza
                local objetivoHitbox = player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Head")
                
                if objetivoHitbox then
                    -- Calcular en qué parte de tu pantalla está ese jugador
                    local vector, onScreen = Camera:WorldToViewportPoint(objetivoHitbox.Position)
                    
                    if onScreen then
                        -- Medir la distancia entre el jugador y tu ratón
                        local distance = (Vector2.new(vector.X, vector.Y) - mouseLocation).Magnitude
                        
                        -- Si la distancia es menor al radio del círculo, ¡ESTÁ EN LA MIRA!
                        if distance <= FOVCircle.Radius then
                            objetivoEncontrado = true
                            break -- Romper el loop, ya encontramos a alguien
                        end
                    end
                end
            end
        end

        -- Si alguien está dentro del círculo verde, dispara
        if objetivoEncontrado then
            DispararCombo()
        end
    end
end)
