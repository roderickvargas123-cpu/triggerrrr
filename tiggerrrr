RunService.RenderStepped:Connect(function()
    if holdingTriggerButton and getgenv().XenoTriggerBot and LocalPlayer.Character then
        
        -- 1. CREAMOS LA LISTA DE BLANCOS VÁLIDOS (El filtro fantasma)
        local blancosValidos = {}
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                
                local char = player.Character
                local isKnocked = false
                local bodyEffects = char:FindFirstChild("BodyEffects")
                
                -- MULTI-FILTRO: Buscamos todos los nombres posibles que usan los clones de Da Hood
                if bodyEffects then
                    if bodyEffects:FindFirstChild("K.O") and bodyEffects["K.O"].Value == true then isKnocked = true end
                    if bodyEffects:FindFirstChild("KO") and bodyEffects["KO"].Value == true then isKnocked = true end
                    if bodyEffects:FindFirstChild("Knocked") and bodyEffects["Knocked"].Value == true then isKnocked = true end
                    if bodyEffects:FindFirstChild("Dead") and bodyEffects["Dead"].Value == true then isKnocked = true end
                end
                
                -- Si NO está noqueado, lo añadimos a la lista de colisiones
                if not isKnocked then
                    table.insert(blancosValidos, char)
                end
            end
        end
        
        -- 2. CONFIGURAMOS EL RAYO PARA QUE SOLO VEA A LOS VALIDOS
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Include
        rayParams.FilterDescendantsInstances = blancosValidos -- Los noqueados no existen para este rayo
        rayParams.IgnoreWater = true
        
        local mousePos = UserInputService:GetMouseLocation()
        local unitRay = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
        
        -- 3. EL DISPARO
        local rayResult = workspace:Raycast(unitRay.Origin, unitRay.Direction * 1000, rayParams)
        
        if rayResult and rayResult.Instance then
            local model = rayResult.Instance:FindFirstAncestorOfClass("Model")
            
            if model and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
                local targetPlayer = Players:GetPlayerFromCharacter(model)
                
                if targetPlayer and targetPlayer ~= LocalPlayer then
                    -- Ya no necesitamos preguntar aquí si está noqueado, 
                    -- porque el rayo es físicamente incapaz de tocar a un noqueado.
                    DispararComboRapido()
                end
            end
        end
    end
end)
