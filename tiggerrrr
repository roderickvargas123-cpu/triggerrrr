UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
        FOVCircle.Visible = screenGui.Enabled
    end

    if not gameProcessed and input.UserInputType == Enum.UserInputType.MouseButton5 then
        holdingMouseButton5 = true
        FOVCircle.Color = Color3.fromRGB(0, 255, 0)
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton5 then
        holdingMouseButton5 = false
        FOVCircle.Color = Color3.fromRGB(255, 0, 0)
    end
end)

local function DispararCombo()
    if firingCombo then return end
    firingCombo = true

    local character = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack

    if character and backpack and character:FindFirstChild("Humanoid") then
        local toolsInBackpack = {}
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                table.insert(toolsInBackpack, item)
            end
        end

        local slotsToFire = {5, 4, 3}

        for _, slotIndex in ipairs(slotsToFire) do
            local toolToEquip = toolsInBackpack[slotIndex]
            
            if toolToEquip then
                character.Humanoid:EquipTool(toolToEquip)
                task.wait(0.05)
                
                if mouse1click then
                    mouse1click()
                else
                    toolToEquip:Activate()
                end
                
                task.wait(0.05)
                character.Humanoid:UnequipTools()
            end
        end
    end

    task.wait(0.5)
    firingCombo = false
end

RunService.RenderStepped:Connect(function()
    local mouseLocation = UserInputService:GetMouseLocation()
    FOVCircle.Position = mouseLocation

    if holdingMouseButton5 and getgenv().XenoTriggerBot then
        local target = Mouse.Target
        
        if target and target.Parent and target.Parent:FindFirstChild("Humanoid") then
            local playerObjetivo = Players:GetPlayerFromCharacter(target.Parent)
            
            if playerObjetivo and playerObjetivo ~= LocalPlayer and target.Parent.Humanoid.Health > 0 then
                local vector, onScreen = Camera:WorldToViewportPoint(target.Position)
                local distance = (Vector2.new(vector.X, vector.Y) - mouseLocation).Magnitude
                
                if distance <= FOVCircle.Radius then
                    DispararCombo()
                end
            end
        end
    end
end)
