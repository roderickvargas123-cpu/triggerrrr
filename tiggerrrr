-- ==========================================
-- CONTROLES
-- ==========================================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
    end

    if not gameProcessed and (input.UserInputType == Enum.UserInputType.MouseButton5 or input.UserInputType == Enum.UserInputType.MouseButton4) then
        holdingTriggerButton = true
        frame.BorderColor3 = Color3.fromRGB(0, 255, 0) -- Borde verde al presionar
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton5 or input.UserInputType == Enum.UserInputType.MouseButton4 then
        holdingTriggerButton = false
        frame.BorderColor3 = Color3.fromRGB(255, 0, 0) -- Borde rojo al soltar
    end
end)

-- ==========================================
-- FUNCIONES DE SIMULACIÓN (CLIC Y TECLADO)
-- ==========================================
local function SimularClic()
    if mouse1press then
        -- mouse1press y mouse1release son más precisos que mouse1click
        mouse1press()
        task.wait(0.02)
        mouse1release()
    else
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.02)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end
end

local function PresionarTecla(tecla)
    VirtualInputManager:SendKeyEvent(true, tecla, false, game)
    task.wait(0.02)
    VirtualInputManager:SendKeyEvent(false, tecla, false, game)
end

-- ==========================================
-- MACRO COMBO (DISPARA -> 4 -> DISPARA -> 5 -> DISPARA)
-- ==========================================
local function DispararCombo()
    if firingCombo then return end
    firingCombo = true

    -- 1. Dispara el arma que ya tienes equipada (ej. la 3)
    SimularClic()
    task.wait(0.05) 

    -- 2. Cambia al arma 4 y dispara
    PresionarTecla(Enum.KeyCode.Four)
    task.wait(0.05) -- Pausa para que el personaje saque el arma
    SimularClic()
    task.wait(0.05)

    -- 3. Cambia al arma 5 y dispara
    PresionarTecla(Enum.KeyCode.Five)
    task.wait(0.05)
    SimularClic()
    
    -- Opcional: Si quieres que vuelva al arma 3 automáticamente después del combo, 
    -- descomenta (quita los dos guiones) de la siguiente línea:
    -- PresionarTecla(Enum.KeyCode.Three)

    task.wait(0.4) -- Cooldown general para no trabar el juego
    firingCombo = false
end

-- ==========================================
-- TRIGGER BOT CLÁSICO E INFALIBLE
-- ==========================================
RunService.RenderStepped:Connect(function()
    if holdingTriggerButton and getgenv().XenoTriggerBot then
        -- Mira exactamente qué está tocando el puntero del mouse
        local target = Mouse.Target
        
        if target then
            -- Busca si el bloque que estamos mirando pertenece a un Modelo (Avatar)
            local model = target:FindFirstAncestorOfClass("Model")
            
            if model and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
                local targetPlayer = Players:GetPlayerFromCharacter(model)
                
                -- Si ese modelo es de un jugador real y no somos nosotros mismos
                if targetPlayer and targetPlayer ~= LocalPlayer then
                    DispararCombo()
                end
            end
        end
    end
end)
